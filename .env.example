# ── Radical Intelligence Platform — Environment Variables ────────────────────
# Copy this file to .env and fill in your keys.
# Keys prefixed with VITE_ are exposed to the browser (safe for API-key-in-header auth).
# Never commit your actual .env file to git.

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Anthropic Claude — powers AI briefings, boolean suggestions, competitor research
# Get yours at: https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...

# ── NEWS MONITORING ───────────────────────────────────────────────────────────

# NewsAPI — primary media ingest (news articles, press coverage)
# Free tier: 100 requests/day | Paid: https://newsapi.org/pricing
VITE_NEWSAPI_KEY=

# ── SOCIAL MONITORING ─────────────────────────────────────────────────────────

# Yutori — RECOMMENDED social provider (Twitter/X, Reddit, LinkedIn, HN)
# docs.yutori.com — $0.35/company/run Research API
VITE_YUTORI_API_KEY=

# Data365 — Reddit, Twitter/X, LinkedIn social monitoring
# https://data365.co
VITE_DATA365_API_KEY=

# Reddit API (direct, free alternative for Reddit monitoring)
# Create app at: https://www.reddit.com/prefs/apps
VITE_REDDIT_CLIENT_ID=
VITE_REDDIT_CLIENT_SECRET=

# ── PORTFOLIO DATA ────────────────────────────────────────────────────────────

# Specter — headcount, funding rounds, web traffic data
# https://specter.ai
VITE_SPECTER_API_KEY=

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# OpenAI — GPT-4o-mini sentiment scoring (falls back to VADER lexicon if unset)
VITE_OPENAI_API_KEY=

# ── COHERE NORTH (Radical private cloud — recommended LLM provider) ──────────
# Your private Cohere deployment at radical.cloud.cohere.com
# Takes priority over Anthropic when set.
VITE_COHERE_NORTH_KEY=your-cohere-north-api-key
VITE_COHERE_NORTH_HOSTNAME=radical.cloud.cohere.com
VITE_COHERE_NORTH_MODEL=command-r-plus
